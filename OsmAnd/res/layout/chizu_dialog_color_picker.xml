<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical"
	android:paddingStart="16dp"
	android:paddingEnd="16dp"
	android:paddingTop="10dp"
	android:paddingBottom="4dp">

	<!-- prior-selected colors, one-click -->
	<LinearLayout
		android:id="@+id/chizu_recent_row"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:layout_marginBottom="8dp" />

	<!-- old | new preview + hex -->
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="36dp"
		android:orientation="horizontal"
		android:layout_marginBottom="8dp">

		<View
			android:id="@+id/chizu_old_color"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_weight="1" />

		<View
			android:id="@+id/chizu_new_color"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_weight="1" />

		<TextView
			android:id="@+id/chizu_hex_value"
			android:layout_width="wrap_content"
			android:layout_height="match_parent"
			android:gravity="center"
			android:paddingStart="10dp"
			android:paddingEnd="0dp"
			android:textSize="14sp"
			android:fontFamily="monospace" />
	</LinearLayout>

	<!-- R / G / B / A slider rows are added here programmatically -->
	<LinearLayout
		android:id="@+id/chizu_sliders_holder"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical" />
</LinearLayout>
